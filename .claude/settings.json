{
  "env": {
    "CLAUDE_CODE_USE_POWERSHELL_TOOL": "1"
  },
  "defaultShell": "powershell",
  "permissions": {
    "allow": [
      "Bash(uv run *)",
      "Bash(uv sync *)",
      "Bash(uv add *)",
      "Bash(pytest *)",
      "Bash(python *)",
      "Bash(ls *)",
      "Bash(find * -type f*)",
      "Bash(grep *)"
    ],
    "deny": [
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git add*)",
      "Bash(git rebase*)",
      "Bash(git reset*)",
      "Bash(git checkout -- *)",
      "Bash(git restore *)"
    ]
  }
}
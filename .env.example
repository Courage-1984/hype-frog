# hype-frog runtime configuration (copy to `.env` — never commit real secrets)
#
# ---------------------------------------------------------------------------
# PageSpeed Insights (PSI)
# ---------------------------------------------------------------------------
# REST API key from Google Cloud Console. Enable the "PageSpeed Insights API"
# for the key's project. Used only when the crawl prompts allow PSI (non-zero
# max PSI URLs). Leave unset to skip PSI calls (scores stay blank with PSI Data Status).
#
# Required IAM: none beyond API enablement; restrict the key by HTTP referrer or
# IP in production per your security policy.
#
# PSI_API_KEY=

# ---------------------------------------------------------------------------
# Google Search Console (GSC)
# ---------------------------------------------------------------------------
# GSC is loaded from OAuth **files**, not from this `.env` file:
#   - Canonical location: `secrets/client_secrets.json` (OAuth 2.0 Client ID,
#     type "Desktop app") and `secrets/token.json` (refreshed user token).
#   - Legacy fallbacks: same filenames under `src/hype_frog/` or the repo root.
#   - The `secrets/` directory is gitignored — see `.gitignore`.
#
# Bootstrap or refresh the token (opens a browser once):
#   uv run hype-frog --gsc-auth
#
# OAuth scope used in code (read-only Search Console):
#   https://www.googleapis.com/auth/webmasters.readonly
#
# The authenticated Google account must have access to the Search Console property
# that matches the crawl target (URL prefix or domain property). Service-account
# JSON is not used by the current implementation; use the Desktop OAuth flow.

# ---------------------------------------------------------------------------
# LLM API keys (search intent classification)
# ---------------------------------------------------------------------------
# Optional. Used when enriching rows with LLM-based search intent. Leave unset or
# blank to skip remote calls — intent classification returns "Unknown" gracefully.
#
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
#
# Override the OpenAI model used for intent classification (defaults to a
# fast/cheap chat model in code).
# OPENAI_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# Optional
# ---------------------------------------------------------------------------
# Override default Excel output path/filename for a run (otherwise auto-generated).
# HF_OUTPUT_FILENAME=

# Override the sitemap URL used by --quick-test / --full-smoke-test.
# Useful when the default public sitemap is unreachable in CI or behind a proxy.
# HF_TEST_SITEMAP_URL=https://example.com/sitemap.xml

# Override BFS crawl depth (default: 3). Set to 1 to crawl only the sitemap seeds.
# HF_MAX_DEPTH=3

# Abort the crawl with a controlled MemoryLimitExceeded error above this RSS
# ceiling (MB), instead of risking an uncontrolled OOM on very large crawls.
# HF_MAX_MEMORY_MB=2048

# Tune the synthetic URL volume used by --full-smoke-test / --full-smoke-test-fast.
# HF_FULL_SMOKE_URL_COUNT=80

# Comma-separated competitor domains/URLs to benchmark against (populates the
# hidden Competitor Benchmarks sheet). Same as --competitors.
# HF_COMPETITORS=competitor-a.com,competitor-b.com

# Path to a previous run's audit output for delta/trend comparison. Same as --previous-run.
# HF_PREVIOUS_AUDIT_PATH=

# Stream rows to the workbook writer instead of retaining the full crawl in
# memory (same as --streaming). Recommended for very large crawls.
# HF_STREAMING=1

# Enable GSC URL Inspection API enrichment: "1"/"limited" for a capped sample,
# "full" for every crawled URL (quota-heavy). Same as --gsc-url-inspection[-full].
# GSC_URL_INSPECTION=

# Validate Open Graph / in-content image URLs with a live HEAD request
# (broken/oversized detection). Same as --check-og-images / --check-images.
# CHECK_OG_IMAGES=1
# CHECK_CONTENT_IMAGES=1

# ---------------------------------------------------------------------------
# Crawl replay snapshots (report-only regeneration)
# ---------------------------------------------------------------------------
# HF_REGEN_REPORT=1          # same as --regen-report (skip crawl; replay latest snapshot)
# HF_SNAPSHOT_ID=<uuid>      # replay a specific stored snapshot
# HF_SNAPSHOT_RETENTION_PER_DOMAIN=10
# HF_SNAPSHOTS_DB_PATH=.cache/crawl_snapshots.sqlite

# ---------------------------------------------------------------------------
# HTML Executive Report (optional, white-label)
# ---------------------------------------------------------------------------
# Set HF_EXPORT_HTML=1 to generate a self-contained HTML executive report
# alongside the xlsx workbook. The .html file shares the same base name and
# directory as the xlsx. Requires no external dependencies to render.
#
# HF_EXPORT_HTML=1
# HF_REPORT_PREPARED_BY=Dieter
# HF_REPORT_CLIENT_NAME=African Marketing Confederation
# HF_REPORT_LOGO_PATH=./assets/client_logo.png   # relative to repo root or hype-frog.exe directory
# HF_REPORT_BRAND_COLOUR=#1e293b
# HF_REPORT_ACCENT_COLOUR=#2563eb
#
# Catppuccin Mocha theme (dark HTML report + JetBrains Mono via Google Fonts CDN):
# HF_REPORT_THEME=mocha
# HF_REPORT_BRAND_COLOUR=#1e1e2e      # optional override (defaults to mocha base)
# HF_REPORT_ACCENT_COLOUR=#94e2d5     # optional override (defaults to mocha teal)
#
# Apply mocha-inspired RAG/heatmap colours to the Excel workbook:
# HF_EXCEL_THEME=mocha
#
# Full palette tables and usage: docs/excel_reporting_standards.md

# ---------------------------------------------------------------------------
# PDF Executive Report (optional)
# ---------------------------------------------------------------------------
# HF_EXPORT_PDF=1
# HF_PDF_CLIENT_NAME=African Marketing Confederation
# HF_PDF_LOGO_PATH=./assets/client_logo.png      # relative to repo root or hype-frog.exe directory
# HF_PDF_PREPARED_BY=Dieter
# HF_PDF_BRAND_COLOUR=#1e293b

# ---------------------------------------------------------------------------
# Workbook rendering toggles (optional; default off — accepts 1/true/yes/on)
# ---------------------------------------------------------------------------
# Diagnostic switches for the .xlsx writer. Leave unset for full styling.
#
# Disable all Excel conditional-formatting RULES (colour scales, data bars,
# CellIs/Formula rules) across every sheet. Static semantic cell fills (e.g.
# zebra striping, KPI card fills) are layout, not conditional formatting, and
# are unaffected by this flag.
# HF_DISABLE_CONDITIONAL_FORMATTING=1
#
# Disable data-validation dropdowns (status lists). Also suppresses header tooltips
# for backward compatibility; prefer HF_DISABLE_TOOLTIPS to target tooltips only.
# HF_DISABLE_DATA_VALIDATION=1
#
# Disable header/cell tooltips (Excel comments) only, leaving dropdowns intact.
# HF_DISABLE_TOOLTIPS=1
#
# Strip outbound URLs and embedded images (=IMAGE) for air-gapped/secure review.
# HF_DISABLE_EXTERNAL_LINKS_AND_IMAGES=1
#
# ---------------------------------------------------------------------------
# Logging / observability
# ---------------------------------------------------------------------------
# HF_RUN_ID=20260629_143022_a1b2c3d4   # optional correlation ID (auto-generated when unset)
# HF_LOG_LEVEL=DEBUG                   # file handler minimum level
# HF_CONSOLE_LOG_LEVEL=INFO              # terminal handler minimum level (--verbose/--quiet override)

# Disable freeze panes on non-core sheets (keep only Main/Executive Briefing frozen).
# HF_DISABLE_NON_CORE_FREEZE_PANES=1
#
# Isolation mode for debugging workbook corruption: disables TOC, cross-sheet
# links, BACK TO DASHBOARD nav, and external links/images.
# HF_DEBUG_EXCEL_ISOLATION_MODE=1

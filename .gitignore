# =========================
# Secrets & Environments
# =========================
.env
.venv/
secrets/
client_secrets.json
token.json

# =========================
# Python Artifacts
# =========================
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# =========================
# App Data & Outputs
# =========================
logs/
data/
reports/
output/

# Note: archive_legacy/ is NOT ignored here. 
# It is best practice to commit it once as a historical backup, 
# and then delete the folder in a future commit once you are 100% stable.

# =========================
# OS & IDE Files
# =========================
.DS_Store
.vscode/
# Notice we are NOT ignoring .cursor/ or uv.lock!

